# App (Expo client)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# App -> backend URL (for Android emulator use 10.0.2.2)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional fallback: insecure direct client Gemini (development only)
EXPO_PUBLIC_ENABLE_INSECURE_CLIENT_GEMINI=false

# Backend
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OCR_RATE_LIMIT_PER_MINUTE=30

# Firebase Admin auth verification
# Option A: provide full JSON in one line
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: use GOOGLE_APPLICATION_CREDENTIALS pointing to service-account file
